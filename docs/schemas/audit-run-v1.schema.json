{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kensan196948g.github.io/pc-optimizer/schemas/audit-run-v1.schema.json",
  "title": "PC Optimizer Audit Run v1",
  "type": "object",
  "required": ["schemaVersion", "runId", "execution", "summary", "ai", "outputs"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "runId": { "type": "string" },
    "execution": {
      "type": "object",
      "properties": {
        "mode": { "type": "string" },
        "whatIf": { "type": "boolean" },
        "executionProfile": { "type": "string" }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "ok": { "type": "integer" },
        "skip": { "type": "integer" },
        "ng": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "ai": { "type": "object", "additionalProperties": true },
    "outputs": { "type": "object", "additionalProperties": true },
    "agentTeams": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
